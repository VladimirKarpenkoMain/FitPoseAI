POSTGRES_DB=fitness_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-database-password

DATABASE_URL=postgresql://postgres:change-this-database-password@db:5432/fitness_db
SECRET_KEY=change-this-backend-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ENABLE_API_DOCS=false

# Use ./nginx.conf for first HTTP bootstrap and certificate issue.
# After the certificate exists, set this to ./nginx.ssl.conf.
NGINX_CONF=./nginx.conf
